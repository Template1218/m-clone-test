# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Backend API, for example:
# VITE_API_BASE_URL=http://localhost:3006

# Evolution image CDN base. Use the delivery URL up to the folder/public-id prefix.
# In Cloudinary dynamic folders, the media-library folder may not be part of the public URL.
# Example:
# VITE_EVOLUTION_CLOUDINARY_BASE_URL=https://res.cloudinary.com/YOUR_CLOUD/image/upload/f_auto,q_auto,w_500/Evolution_Live_icon
# Optional: set after re-uploading to bypass cached 404s. Accepts either 1780666689 or v1780666689.
# VITE_EVOLUTION_CLOUDINARY_VERSION=1780666689
